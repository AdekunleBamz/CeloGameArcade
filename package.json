{
  "name": "celo-game-arcade",
  "version": "1.0.0",
  "description": "Farcaster mini app arcade on Celo with on-chain scoring and prize pool",
  "private": true,
  "engines": {"node": ">=18.0.0"},
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "sdk:install": "npm --prefix packages/celo-arcade-sdk ci",
    "sdk:build": "npm --prefix packages/celo-arcade-sdk run build",
    "sdk:test": "npm --prefix packages/celo-arcade-sdk run test",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "check:fast": "npm run sdk:test && npm run lint",
    "validate": "npm run typecheck && npm run check:fast"
  },
  "dependencies": {
    "@farcaster/frame-sdk": "^0.0.26",
    "@farcaster/miniapp-sdk": "^0.2.1",
    "@farcaster/miniapp-wagmi-connector": "^1.1.0",
    "@tanstack/react-query": "^5.51.1",
    "@walletconnect/ethereum-provider": "^2.23.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.17.4",
    "wagmi": "^2.12.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5"
  },
  "author": "adekunlebamz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdekunleBamz/CeloGameArcade.git"
  }
}
